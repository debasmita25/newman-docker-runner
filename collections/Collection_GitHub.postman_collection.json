  "item": [
    {
      "name": "1_Create_Repository",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "pm.test(\"Status Code is 201\",function()\r",
              "{\r",
              "    pm.response.to.have.status(201);\r",
              "}\r",
              "\r",
              ");\r",
              "var jsonBody = pm.response.json();\r",
              "pm.test(\"Response Body contains the correct repository name\", function () {\r",
              "    pm.expect(jsonBody.name).to.equal(pm.environment.get(\"repoName\"));\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let timestamp=Date.now();\r",
              "\r",
              "let repoName=\"repo_\"+timestamp;\r",
              "\r",
              "pm.environment.set(\"repoName\", repoName);\r",
              "console.log(\"Repo Name : \"+repoName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{GITHUB_TOKEN}}"
          },
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          },
          {
            "key": "X-GitHub-Api-Version",
            "value": "2022-11-28",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n\"name\":\"{{repoName}}\",\r\n\"description\":\"Repository created via Postman API test\",\r\n\"private\":false\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/user/repos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        },
        "description": "Generated from cURL: curl -X POST https://api.github.com/user/repos \\\r\n-H \"Authorization: Bearer YOUR_TOKEN\" \\\r\n-H \"Accept: application/vnd.github+json\" \\\r\n-d '{\r\n\"name\":\"api-testing-repo\",\r\n\"description\":\"created using curl\",\r\n\"private\":false\r\n}'"
      },
      "response": []
    },
    {
      "name": "2_Get_Repository",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Check the response time is within 500 ms\",function(){\r",
              "pm.expect(pm.response.responseTime).to.be.lessThan(500);\r",
              "});\r",
              "\r",
              "pm.test(\"Check if the security header has X-Frame-Options as deny \",function(){\r",
              "    pm.expect(pm.response.headers.get(\"X-Frame-Options\")).to.eql(\"deny\");\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              "var jsonBody=pm.response.json();\r",
              "pm.test(\"fullname has repo name\",function(){\r",
              "pm.expect(jsonBody.full_name).to .include(pm.environment.get(\"repoName\"));\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/repos/{{GITHUB_USERNAME}}/{{repoName}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "repos",
            "{{GITHUB_USERNAME}}",
            "{{repoName}}"
          ]
        }
      },
      "response": []

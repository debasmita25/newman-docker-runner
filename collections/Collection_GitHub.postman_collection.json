    {
      "name": "7_Search_Repository",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status to be 200\",function(){\r",
              "\r",
              "pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"total_count to be greater than 0\",function(){\r",
              "pm.expect(pm.response.json().total_count).to.be.greaterThan(0);});\r",
              "\r",
              "pm.test(\"total_count is number\",function()\r",
              "{\r",
              " pm.expect(pm.response.json().total_count).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "//default page limit\r",
              "pm.test(\"check the length of items array is equal to or less than 30\",function()\r",
              "{\r",
              "pm.expect(pm.response.json().items.length).to.be.lessThanOrEqual(30);\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],

            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Description updated\", function () {\r",
              "    pm.expect(jsonData.description).to.eql(\"Updated description via API automation\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{GITHUB_TOKEN}}"
          },
          {
            "key": "Accept",
            "value": "application/vnd.github+json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"description\": \"Updated description via API automation\",\r\n  \"private\": true\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/repos/{{GITHUB_USERNAME}}/{{repoName}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "repos",
            "{{GITHUB_USERNAME}}",
            "{{repoName}}"
          ]
        },
        "description": "Generated from cURL: curl -X PATCH https://api.github.com/repos/USERNAME/api-testing-repo \\\r\n-H \"Authorization: Bearer YOUR_TOKEN\" \\\r\n-H \"Accept: application/vnd.github+json\" \\\r\n-d '{\r\n  \"description\": \"Updated description via API\",\r\n  \"private\": true\r\n}'"
      },
      "response": []

    {
      "name": "4_Add_Repository_Topics",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonBody=pm.response.json();\r",
              "pm.test(\"the three topics are attached to Repo\",function()\r",
              "{\r",
              " pm.expect(jsonBody.names).to.have.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"topics array has correct number of elements\",function() \r",
              "{\r",
              "    pm.expect(jsonBody.names.length).to.equal(3);\r",
              "    pm.expect(jsonBody.names[0]).to.equal(pm.environment.get(\"topicname1\"));\r",
              "     pm.expect(jsonBody.names[1]).to.equal(pm.environment.get(\"topicname2\"));\r",
              "      pm.expect(jsonBody.names[2]).to.equal(pm.environment.get(\"topicname3\"));\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
